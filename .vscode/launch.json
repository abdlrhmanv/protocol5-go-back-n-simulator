{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug protocol5_sim (default scenario)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/protocol5_sim",
      "args": ["0", "0", "12", "8000", "0", "1"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build (debug)",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
      "name": "Debug protocol5_sim (loss + corrupt)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/protocol5_sim",
      "args": ["20", "20", "12", "30000", "20", "7"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build (debug)",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}
